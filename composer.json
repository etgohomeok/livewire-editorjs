{
    "name": "etgohomeok/livewire-editorjs",
    "description": "Editor.js integration for Laravel Livewire.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "livewire", "editor", "editorjs", "wysiwyg"],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "EthanJenkins\\LivewireEditorjs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EthanJenkins\\LivewireEditorjs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EthanJenkins\\LivewireEditorjs\\LivewireEditorjsServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
